{
  "name": "scl-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:proxy\"",
    "dev:vite": "vite --port 5173",
    "dev:proxy": "node proxy-server.mjs",
    "build": "tsc && vite build",
