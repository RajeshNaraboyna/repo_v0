# =============================================================================
# School Management System — All-in-One Docker Deployment (.env)
# =============================================================================
# Used by: docker compose -f docker-compose.allinone.yml up -d --build
# All variables have safe defaults; update secrets before production use.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=scluser
POSTGRES_PASSWORD=sclpass
POSTGRES_DB=school_mgmt
# Host port that postgres is exposed on (inside container is always 5432)
POSTGRES_HOST_PORT=5433

# -----------------------------------------------------------------------------
# Application (API + RAG)
# -----------------------------------------------------------------------------
APP_ENV=production
DEBUG=false

# -----------------------------------------------------------------------------
# Supabase
# Get these from Supabase Dashboard > Settings > API

# Supabase Auth
SUPABASE_URL=https://aizsdxmtfvbruahpogfx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFpenNkeG10ZnZicnVhaHBvZ2Z4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY2NzI1NTYsImV4cCI6MjA5MjI0ODU1Nn0.9wOUgCN-EgzEKp5jJ4IFfqBx-rA_1Gyxlk2PK7AyaXA
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFpenNkeG10ZnZicnVhaHBvZ2Z4Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NjY3MjU1NiwiZXhwIjoyMDkyMjQ4NTU2fQ.ksMpj030RTUHDHDiQeR6ScDZpoJ-CExL6DQJDM6Lm9k
# Legacy HS256 JWT secret (Dashboard > Settings > API > JWT Settings > JWT Secret)
SUPABASE_JWT_SECRET=oQcghFRifOYc+9S8azmMehEBmxSiLsdYd6R8XF+4QRJeHmlYk3yT4s+k6yErbMJMxGamNUHa75GyvmGa7w61jQ==

# JWKS endpoint for verifying P-256 signed JWTs (current Supabase default)
SUPABASE_JWKS_URL=https://aizsdxmtfvbruahpogfx.supabase.co/auth/v1/.well-known/jwks.json

# -----------------------------------------------------------------------------
# API — Security
# IMPORTANT: Replace SECRET_KEY with a random 64-char string before deploying
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# -----------------------------------------------------------------------------
# API — CORS
# JSON array of allowed origins. Must include the URL users access the app from.
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:4001", "http://localhost:5173", "http://localhost:3000", "http://10.96.172.57:4001"]

# -----------------------------------------------------------------------------
# API — Guest access
# -----------------------------------------------------------------------------
GUEST_ACCESS_ENABLED=true
GUEST_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# RAG — Milvus connection (use service name "milvus" inside Docker network)
# -----------------------------------------------------------------------------
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=student_results
MILVUS_DB_NAME=default

# -----------------------------------------------------------------------------
# RAG — Embedding model
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# -----------------------------------------------------------------------------
# Internal service URL (API → RAG, loopback inside the all-in-one container)
# -----------------------------------------------------------------------------
RAG_SERVICE_URL=http://127.0.0.1:4003

# -----------------------------------------------------------------------------
# Host port mappings (change if the default ports are already in use)
# -----------------------------------------------------------------------------
FRONTEND_HOST_PORT=4001
API_HOST_PORT=4002
RAG_HOST_PORT=4003
