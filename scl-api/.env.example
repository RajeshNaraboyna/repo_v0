# Application Settings
APP_NAME=school-management-api
APP_ENV=development
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=4002

# Database Settings (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:<DB_PASSWORD>@db.aizsdxmtfvbruahpogfx.supabase.co:5432/postgres

# Supabase Auth
SUPABASE_URL=https://aizsdxmtfvbruahpogfx.supabase.co
# Anon key — from Supabase Dashboard > Settings > API > Project API keys
SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Service role key — from Supabase Dashboard > Settings > API > Project API keys
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
# JWT secret — from Supabase Dashboard > Settings > API > JWT Settings
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>

# Legacy local JWT (still used for guest tokens)
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:4001", "http://localhost:5173", "http://localhost:3000"]

# Guest User Settings
GUEST_ACCESS_ENABLED=true
GUEST_TOKEN_EXPIRE_MINUTES=60
