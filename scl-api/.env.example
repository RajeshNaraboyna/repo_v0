# Application Settings
APP_NAME=school-management-api
APP_ENV=development
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=4002

# Database Settings
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/school_mgmt
# For SQLite (development): DATABASE_URL=sqlite+aiosqlite:///./school_mgmt.db

# Security
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:4001", "http://localhost:5173"]

# Guest User Settings
GUEST_ACCESS_ENABLED=true
GUEST_TOKEN_EXPIRE_MINUTES=60
